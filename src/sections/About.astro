---
import Section from "../components/Section.astro";
import { profile } from "../data/profile";
---

<Section id="about" title="cat about.txt">
  <div class="grid gap-10 md:grid-cols-2 md:items-start">
    <div class="space-y-5">
      {
        profile.about.map((paragraph) => (
          <p class="text-base leading-relaxed text-text-secondary">{paragraph}</p>
        ))
      }

      <a
        href={profile.resumeUrl}
        class="inline-flex rounded-full border border-cyan px-5 py-2.5 font-mono text-sm text-cyan transition hover:bg-cyan/10 focus:outline-none focus:ring-2 focus:ring-cyan"
      >
        Download Resume
      </a>
    </div>

    <aside class="mx-auto w-full max-w-xs">
      <div class="rounded-lg bg-gradient-to-br from-cyan/40 via-transparent to-amber/30 p-[1px]">
        <div class="flex aspect-square items-center justify-center rounded-lg border border-border bg-surface">
          <span class="font-mono text-sm text-text-secondary">avatar.placeholder</span>
        </div>
      </div>
    </aside>
  </div>
</Section>

