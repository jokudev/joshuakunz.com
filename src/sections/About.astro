---
import Section from "../components/Section.astro";
import { profile } from "../data/profile";
---

<Section id="about" title="whoami">
  <div class="grid gap-10 md:grid-cols-2 md:items-start">
    <div class="space-y-5">
      {
        profile.about.map((paragraph) => (
          <p class="text-base leading-relaxed text-text-secondary">{paragraph}</p>
        ))
      }

      <a
        href={profile.cvUrl}
        class="inline-flex rounded-full border border-cyan px-5 py-2.5 font-mono text-sm text-cyan transition hover:bg-cyan/10 focus:outline-none focus:ring-2 focus:ring-cyan"
      >
        Lebenslauf PDF
      </a>
    </div>

    <aside class="mx-auto w-full max-w-xs">
      <div class="space-y-4">
        <div>
          <h3 class="mb-2 text-xs font-mono uppercase tracking-widest text-text-secondary">Sprachen</h3>
          <div class="space-y-1">
            {
              profile.languages.map((lang) => (
                <p class="text-sm text-text-secondary">{lang.name} — {lang.level}</p>
              ))
            }
          </div>
        </div>
        <div>
          <h3 class="mb-2 text-xs font-mono uppercase tracking-widest text-text-secondary">Interessen</h3>
          <div class="flex flex-wrap gap-2">
            {
              profile.interests.map((interest) => (
                <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs text-text-secondary">
                  {interest}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </aside>
  </div>
</Section>
