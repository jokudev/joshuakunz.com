---
import { profile } from "../data/profile";
---

<section class="flex min-h-[calc(100vh-4rem)] items-center px-6 py-20 md:py-32">
  <div class="mx-auto w-full max-w-5xl">
    <div class="reveal is-visible">
      <p class="font-mono text-sm text-cyan">class: devops-engineer</p>
      <h1 class="mt-4 text-5xl font-mono font-bold tracking-tight text-text-primary md:text-7xl">{profile.name}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-secondary">
        {profile.subtitle}<span class="ml-1 inline-block animate-pulse font-mono text-cyan">|</span>
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#projects"
          class="rounded-full border border-amber px-6 py-3 font-mono text-sm text-amber transition hover:bg-amber/10 focus:outline-none focus:ring-2 focus:ring-cyan"
        >
          View Projects
        </a>
        <a
          href="#contact"
          class="rounded-full border border-cyan px-6 py-3 font-mono text-sm text-cyan transition hover:bg-cyan/10 focus:outline-none focus:ring-2 focus:ring-cyan"
        >
          Contact Me
        </a>
      </div>

      <pre class="mt-12 overflow-x-auto rounded-lg border border-border bg-surface p-4 text-xs text-text-secondary md:text-sm">
&gt; ------------------------------------------------------------
&gt; resilient_systems = pipelines + observability + reliability
&gt; ------------------------------------------------------------
      </pre>
    </div>
  </div>
</section>

