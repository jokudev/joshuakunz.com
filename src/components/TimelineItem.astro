---
type Props = {
  item: any;
};

const { item } = Astro.props;
---

<article class="relative grid grid-cols-[20px_1fr] gap-x-4 gap-y-3 md:grid-cols-[1fr_20px_1fr] md:gap-8">
  <time class="col-start-2 text-sm font-mono text-text-secondary md:col-start-1 md:text-right">{item.period}</time>

  <div class="relative row-span-2">
    <span class="absolute left-1/2 top-1 block h-2 w-2 -translate-x-1/2 rounded-full bg-cyan"></span>
  </div>

  <div class="col-start-2 rounded-lg border border-border bg-surface p-6 transition duration-300 hover:border-cyan/30 hover:bg-surface-hover hover:shadow-[0_0_20px_rgba(34,211,238,0.15)] md:col-start-3">
    <h3 class="text-xl font-semibold text-text-primary">{item.title}</h3>
    <p class="mt-1 text-sm font-mono text-text-secondary">{item.institution}</p>
    {item.location && (
      <p class="text-xs text-text-secondary">{item.location}</p>
    )}
  </div>
</article>
