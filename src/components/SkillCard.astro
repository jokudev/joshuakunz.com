---
type Props = {
  category: string;
  items: string[];
};

const { category, items } = Astro.props;
---

<article
  class="rounded-lg border border-border bg-surface p-6 transition duration-300 hover:border-cyan/30 hover:bg-surface-hover hover:shadow-[0_0_20px_rgba(34,211,238,0.15)]"
>
  <h3 class="mb-4 text-xl font-semibold text-text-primary">{category}</h3>

  <div class="flex flex-wrap gap-2">
    {
      items.map((item: string) => (
        <span class="pill">{item}</span>
      ))
    }
  </div>
</article>
