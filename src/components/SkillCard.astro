---
import { Cloud, Code2, Container, LineChart, Workflow } from "lucide-astro";
import type { SkillCategory } from "../data/profile";

type Props = {
  skill: SkillCategory;
};

const { skill } = Astro.props;

const iconMap = {
  cloud: Cloud,
  container: Container,
  workflow: Workflow,
  "line-chart": LineChart,
  code: Code2
};

const Icon = iconMap[skill.icon];
---

<article
  class="rounded-lg border border-border bg-surface p-6 transition duration-300 hover:border-cyan/30 hover:bg-surface-hover hover:shadow-[0_0_20px_rgba(34,211,238,0.15)]"
>
  <div class="mb-4 flex items-center gap-3">
    <Icon class="h-5 w-5 text-cyan" aria-hidden="true" />
    <h3 class="text-xl font-semibold text-text-primary">{skill.category}</h3>
  </div>

  <div class="flex flex-wrap gap-2">
    {
      skill.items.map((item) => (
        <span class="pill">{item}</span>
      ))
    }
  </div>
</article>

