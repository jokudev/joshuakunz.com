---
import { Github, ExternalLink } from "lucide-astro";

type Props = {
  project: any;
};

const { project } = Astro.props;
---

<article
  class="rounded-lg border border-border bg-surface p-5 transition duration-300 hover:border-cyan/30 hover:bg-surface-hover hover:shadow-[0_0_20px_rgba(34,211,238,0.15)]"
>
  <div class="mt-4">
    <div class="flex items-center justify-between gap-4">
      <h3 class="text-xl font-semibold text-text-primary">{project.title}</h3>
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noreferrer"
          class="text-cyan transition-colors hover:text-amber focus:outline-none focus:ring-2 focus:ring-cyan"
          aria-label={`Zum Demo für ${project.title}`}
        >
          <ExternalLink class="h-5 w-5" />
        </a>
      )}
    </div>

    <p class="mt-3 text-base leading-relaxed text-text-secondary">{project.description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {
        project.tags.map((tag: string) => (
          <span class="pill">{tag}</span>
        ))
      }
    </div>

    <ul class="mt-4 space-y-1 text-sm text-text-secondary">
      {
        project.bullets.map((bullet: string) => (
          <li class="flex gap-2">
            <span class="text-cyan">→</span>
            <span>{bullet}</span>
          </li>
        ))
      }
    </ul>

    <div class="mt-5 flex items-center gap-5 text-sm font-mono">
      {project.repo && (
        <a
          href={project.repo}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 text-cyan transition-colors hover:text-amber focus:outline-none focus:ring-2 focus:ring-cyan"
        >
          <Github class="h-4 w-4" /> Repository
        </a>
      )}
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 text-cyan transition-colors hover:text-amber focus:outline-none focus:ring-2 focus:ring-cyan"
        >
          <ExternalLink class="h-4 w-4" /> Live
        </a>
      )}
    </div>
  </div>
</article>
